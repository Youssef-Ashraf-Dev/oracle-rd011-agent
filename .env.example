# ── LLM Provider API Keys ─────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GROQ_API_KEY=your-groq-api-key-here
MISTRAL_API_KEY=your-mistral-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Paths (optional — defaults shown) ────────────────────────────────────
# CHECKPOINT_DB_PATH=checkpoints/rd011_checkpoints.db
# OUTPUT_DIR=outputs/
# TEMPLATE_PATH=templates/RD011_TEMPLATE.docx

# ── Generation Config (optional) ─────────────────────────────────────────
# MAX_RETRIES=3
# TOP_K_RETRIEVAL=5
# ENABLE_REPAIR_PASS=true
# GENERATION_THROTTLE_SECONDS=0
# GENERATION_THROTTLE_ON_FAILURE_ONLY=true
RAG_ENABLED=false

# ── RAG / Embeddings (optional) ───────────────────────────────────────────────
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cpu
# RAG_COLLECTION_NAME=rd011_examples_local
# RAG_ALLOWED_SOURCES=RD011_OWEST_FIN_Future_Process_V3.docx,RD.011_RIS_Saudi Cement_Finance_Future Process Model_09Jan25_V2.0_Final.docx
# RAG_MAX_CONTEXT_CHARS=8000
# RAG_MAX_CHUNK_CHARS=2000
# RAG_MAX_CHUNKS_PER_SOURCE=2
# RAG_RETRIEVE_CACHE_MAX_ENTRIES=512
# RAG_TRACE_RETRIEVAL=true
# RAG_TRACE_PREVIEW_CHARS=160
